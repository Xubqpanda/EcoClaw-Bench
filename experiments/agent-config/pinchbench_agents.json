        "model": "dmx/gpt-5.4-mini",
        "skills": [
          "coding-agent",
          "code-style",
          "github",
          "debugger"
        ]
      },
      {
        "id": "researcher",
        "name": "Research Agent",
        "model": "dmx/gpt-5.4-mini",
        "skills": [
          "tavily",
          "search-first",
          "data-analyst",
