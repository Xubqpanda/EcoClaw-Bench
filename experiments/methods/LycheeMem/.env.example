# LycheeMem .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM（litellm 统一格式：provider/model-name）───
# 格式说明：
#   OpenAI / 兼容代理：openai/<model>    例：openai/gpt-4o-mini
#   Gemini：           gemini/<model>    例：gemini/gemini-2.0-flash
#   Ollama：           ollama_chat/<model> 例：ollama_chat/qwen2.5
LLM_MODEL=
LLM_API_KEY=
LLM_API_BASE=

# ─── Embedder（litellm 统一格式）───
EMBEDDING_MODEL=
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

SQLITE_DB_PATH=data/sessions.db
USER_DB_PATH=data/users.db

SKILL_DB_PATH=data/skill_store.db
SKILL_VECTOR_DB_PATH=data/skill_vector

COMPACT_MEMORY_DB_PATH=data/compact_memory.db
COMPACT_VECTOR_DB_PATH=data/compact_vector

MIN_RECENT_TURNS=4
SKILL_TOP_K=3